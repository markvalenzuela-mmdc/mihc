# Postgres
DATABASE_URL=postgresql://app:app@localhost:5432/platform


# MinIO / S3-compatible storage
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=artifacts
S3_FORCE_PATH_STYLE=true

# Web
WEB_PORT=3000
API_PORT=3001

# Inngest
INNGEST_DEV=1