# Postgres
DATABASE_URL=postgresql://app:app@localhost:5432/platform

# Redis
REDIS_URL=redis://localhost:6379

# MinIO (S3-compatible)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=artifacts
S3_FORCE_PATH_STYLE=true

# Web
WEB_PORT=3000
API_PORT=3001