                      />
                    ))
                  ) : (
                    <span className="h-1.5 flex-1 rounded-full bg-muted" />
                  )}
                </div>
                <p className="text-xs text-muted-foreground">
                  {latestRun
                    ? `Checked ${format(latestRun.checkedAt, "MMM d, yyyy h:mm a")}`
