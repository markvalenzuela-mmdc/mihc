      error: { message: "Invalid email or password." },
    });
    render(<LoginForm />);

    fillValidCredentials();
    fireEvent.submit(screen.getByRole("form", { name: "Log in" }));

    expect(
      await screen.findByText("Invalid email or password."),
    ).toBeVisible();
    expect(push).not.toHaveBeenCalled();
  });
});
