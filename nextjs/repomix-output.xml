        <Button
          type="button"
          onClick={onAutomated}
          disabled={selectionLocked || !canRun}
        >
          <PlayIcon className="size-4" />
          Run selected steps locally
        </Button>
        <Button
          type="button"
          variant="outline"
          onClick={onManual}
          disabled={!canRun}
        >
