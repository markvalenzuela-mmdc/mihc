{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./enrollmate-form-definition.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schemaVersion",
    "metadata",
    "applicationTypes",
    "reusableOptionSets",
    "reusableDependentOptionSets",
    "templates",
    "flows"
  ],
  "properties": {
    "$schema": {
      "const": "./enrollmate-form-definition.schema.json"
    },
    "schemaVersion": {
      "const": 1
    },
    "metadata": {
      "$ref": "#/$defs/metadata"
    },
    "applicationTypes": {
      "$ref": "#/$defs/applicationTypes"
    },
    "reusableOptionSets": {
      "$ref": "#/$defs/reusableOptionSets"
    },
    "reusableDependentOptionSets": {
      "$ref": "#/$defs/reusableDependentOptionSets"
    },
    "templates": {
      "$ref": "#/$defs/templates"
    },
    "flows": {
      "$ref": "#/$defs/flows"
    }
  },
  "$defs": {
    "option": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "value"
      ],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "type": "string"
        }
      }
    },
    "conditionValue": {
      "type": [
        "string",
        "boolean"
      ]
    },
    "visibleWhen": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "field",
        "equalsAny"
      ],
      "properties": {
        "field": {
          "type": "string",
          "minLength": 1
        },
        "equalsAny": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/conditionValue"
          }
        }
      }
    },
    "cascade": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dependsOn": {
          "type": "string",
          "minLength": 1
        },
        "triggers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "anyOf": [
        {
          "required": [
            "dependsOn"
          ]
        },
        {
          "required": [
            "triggers"
          ]
        }
      ]
    },
    "automation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "isCascadeParent": {
          "type": "boolean"
        },
        "triggers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "exampleOptionsByParent": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "optionSource": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "options"
          ],
          "properties": {
            "kind": {
              "const": "inline"
            },
            "options": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/option"
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "field",
            "optionSet"
          ],
          "properties": {
            "kind": {
              "const": "dependentReusable"
            },
            "field": {
              "type": "string",
              "minLength": 1
            },
            "optionSet": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "optionSet"
          ],
          "properties": {
            "kind": {
              "const": "reusable"
            },
              "optionSet": {
                "type": "string",
                "minLength": 1
              }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "field",
            "optionsByValue"
          ],
          "properties": {
            "kind": {
              "const": "dependent"
            },
            "field": {
              "type": "string",
              "minLength": 1
            },
            "optionsByValue": {
              "type": "object",
              "additionalProperties": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "$ref": "#/$defs/option"
                }
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind"
          ],
          "properties": {
            "kind": {
              "const": "cascade"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind"
          ],
          "properties": {
            "kind": {
              "const": "external"
            }
          }
        }
      ]
    },
    "upload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "acceptedFormats",
        "maxSizeBytes"
      ],
      "properties": {
        "acceptedFormats": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "maxSizeBytes": {
          "type": "integer",
          "exclusiveMinimum": 0
        }
      }
    },
    "field": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "label",
        "type",
        "required"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "enum": [
            "text",
            "textarea",
            "email",
            "tel",
            "date",
            "select",
            "combobox",
            "checkbox",
            "file"
          ]
        },
        "required": {
          "type": "boolean"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "htmlInputType": {
          "type": "string",
          "minLength": 1
        },
        "placeholder": {
          "type": "string"
        },
        "placeholderValue": {
          "type": "string"
        },
        "defaultValue": {
          "$ref": "#/$defs/conditionValue"
        },
        "visibleWhen": {
          "$ref": "#/$defs/visibleWhen"
        },
        "requiredWhenVisible": {
          "type": "boolean"
        },
        "cascade": {
          "$ref": "#/$defs/cascade"
        },
        "automation": {
          "$ref": "#/$defs/automation"
        },
        "optionSource": {
          "$ref": "#/$defs/optionSource"
        },
        "upload": {
          "$ref": "#/$defs/upload"
        }
      },
      "oneOf": [
        {
          "properties": {
            "type": {
              "enum": [
                "text",
                "textarea",
                "email",
                "tel",
                "date",
                "checkbox"
              ]
            }
          },
          "not": {
            "anyOf": [
              {
                "required": [
                  "optionSource"
                ]
              },
              {
                "required": [
                  "upload"
                ]
              }
            ]
          }
        },
        {
          "properties": {
            "type": {
              "enum": [
                "select",
                "combobox"
              ]
            }
          },
          "required": [
            "optionSource"
          ],
          "not": {
            "required": [
              "upload"
            ]
          }
        },
        {
          "properties": {
            "type": {
              "const": "file"
            }
          },
          "required": [
            "upload"
          ],
          "not": {
            "required": [
              "optionSource"
            ]
          }
        }
      ]
    },
    "section": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "fields"
      ],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "string",
          "minLength": 1
        },
        "prefix": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "const": "checkboxGroup"
        },
        "required": {
          "type": "boolean"
        },
        "fields": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/field"
          }
        }
      }
    },
    "flow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "steps"
      ],
      "properties": {
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "step",
              "title",
              "sections"
            ],
            "properties": {
              "step": {
                "type": "integer",
                "minimum": 1
              },
              "title": {
                "type": "string",
                "minLength": 1
              },
              "sections": {
                "type": "array",
                "items": {
                  "$ref": "#/$defs/section"
                }
              }
            }
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "application",
        "version",
        "referenceDate",
        "source",
        "sourceNotes"
      ],
      "properties": {
        "application": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "referenceDate": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "sourceNotes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "applicationTypes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bachelors",
        "microcredentials"
      ],
      "properties": {
        "bachelors": {
          "$ref": "#/$defs/applicationType"
        },
        "microcredentials": {
          "$ref": "#/$defs/applicationType"
        }
      }
    },
    "applicationType": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "endpoint",
        "totalSteps"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "endpoint": {
          "type": "string",
          "minLength": 1
        },
        "totalSteps": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "reusableOptionSets": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/options"
      }
    },
    "templates": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "addressFieldsPattern"
      ],
      "properties": {
        "addressFieldsPattern": {
          "$ref": "#/$defs/addressFieldsPattern"
        }
      }
    },
    "reusableDependentOptionSets": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "options": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/option"
      }
    },
    "addressFieldsPattern": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "description",
        "fields"
      ],
      "properties": {
        "description": {
          "type": "string",
          "minLength": 1
        },
        "fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/addressFieldTemplate"
          }
        }
      }
    },
    "addressFieldTemplate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "type",
        "required"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "enum": [
            "text",
            "select"
          ]
        },
        "required": {
          "type": "boolean"
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "defaultValue": {
          "type": "string"
        },
        "cascade": {
          "$ref": "#/$defs/cascade"
        }
      }
    },
    "flows": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bachelors",
        "microcredentials"
      ],
      "properties": {
        "bachelors": {
          "$ref": "#/$defs/flow"
        },
        "microcredentials": {
          "$ref": "#/$defs/flow"
        }
      }
    }
  }
}
